    "import pandas as pd\n",
    "\n",
    "students = {\n",
    "    \"Name\": [\"Nazmul\", \"Rahim\", \"Karim\"],\n",
    "    \"Marks\": [85, 90, 75]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(students)\n",
    "\n",
    "average = df[\"Marks\"].mean()\n",
    "\n",
    "print(\"Class Average:\", average)"
   ]
  }
